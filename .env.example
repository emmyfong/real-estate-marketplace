# ---------------------------------------------------------------------------
# Backend (AWS) configuration. Used by the seed script, the local API server,
# and the Lambda handlers.
# ---------------------------------------------------------------------------

# AWS region for your DynamoDB table and Lambda functions.
AWS_REGION=us-west-2

# DynamoDB table name. Must match the table name your CDK stack creates.
PROPERTIES_TABLE=Properties

# Local-only: point the AWS SDK at DynamoDB Local instead of real AWS.
# Leave this UNSET in production (the Lambda talks to real DynamoDB).
# For local dev with `docker compose up`, use: http://localhost:8000
DYNAMODB_ENDPOINT=http://localhost:8000

# Local-only dummy credentials so the SDK is satisfied when talking to
# DynamoDB Local. Real AWS uses your configured credentials / IAM role.
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# ---------------------------------------------------------------------------
# Frontend (Vercel) configuration.
# ---------------------------------------------------------------------------

# Base URL of the deployed AWS HTTP API (API Gateway). For local dev this is
# the local API server started by `npm run dev:api`.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Mapbox PUBLIC access token (starts with "pk."). Get one at
# https://account.mapbox.com/access-tokens/. Never use a secret ("sk.") token
# here — this value ships to the browser. Restrict it to your domain in the
# Mapbox dashboard before deploying.
NEXT_PUBLIC_MAPBOX_TOKEN=
